# PostgreSQL (OLTP source)
POSTGRES_USER=hr_user
POSTGRES_PASSWORD=hr_pass
POSTGRES_DB=hr_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# MySQL (Analytical / Warehouse layer)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=hr_warehouse
MYSQL_USER=hr_analyst
MYSQL_PASSWORD=hr_mysql_pass
MYSQL_ROOT_PASSWORD=root_pass

# Generator config
GENERATOR_EMPLOYEE_COUNT=10000
GENERATOR_YEARS=3
GENERATOR_SEED=42

# ── Airflow orchestration (Phase 6) ──
# Bật bằng: docker compose --profile airflow up -d --build
# Metadata DB + executor được set trong docker-compose.yml (airflow_postgres + LocalExecutor),
# KHÔNG cần set ở đây. Phần dưới là config tùy chọn cho DAG.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Alert attrition: gửi Slack khi rate quý gần nhất vượt ngưỡng (để trống = chỉ log)
SLACK_WEBHOOK_URL=
ATTRITION_ALERT_THRESHOLD=10
